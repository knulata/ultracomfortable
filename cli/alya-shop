#!/bin/bash

# AlyaNoor Shop CLI - Command line interface for browsing and buying from AlyaNoor
# Usage: ./alya-shop <command> [options]

# Configuration
BASE_URL="${ALYA_API_URL:-http://localhost:3000/api}"
SESSION_ID="${ALYA_SESSION_ID:-agent-$(date +%s)}"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color
BOLD='\033[1m'

# Helper functions
print_header() {
    echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${BOLD}${CYAN}  UC Shop - AlyaNoor CLI${NC}"
    echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
}

format_price() {
    printf "Rp %'d" "$1"
}

# Commands
cmd_help() {
    print_header
    echo ""
    echo -e "${BOLD}USAGE:${NC}"
    echo "  alya-shop <command> [options]"
    echo ""
    echo -e "${BOLD}COMMANDS:${NC}"
    echo -e "  ${GREEN}products${NC}              List all products"
    echo -e "  ${GREEN}search${NC} <query>        Search products by name/description"
    echo -e "  ${GREEN}category${NC} <cat>        Filter by category (tops, bottoms, dresses, outerwear, accessories)"
    echo -e "  ${GREEN}product${NC} <slug>        View product details"
    echo -e "  ${GREEN}add${NC} <slug> [options]  Add product to cart"
    echo -e "  ${GREEN}cart${NC}                  View cart"
    echo -e "  ${GREEN}remove${NC} <variant-id>   Remove item from cart"
    echo -e "  ${GREEN}clear${NC}                 Clear cart"
    echo -e "  ${GREEN}checkout${NC} [options]    Place order"
    echo -e "  ${GREEN}orders${NC}                View your orders"
    echo -e "  ${GREEN}order${NC} <order-id>      View order details"
    echo ""
    echo -e "${BOLD}ADD OPTIONS:${NC}"
    echo "  --size <size>         Specify size (default: first available)"
    echo "  --color <color>       Specify color (default: first available)"
    echo "  --qty <quantity>      Quantity to add (default: 1)"
    echo ""
    echo -e "${BOLD}CHECKOUT OPTIONS:${NC}"
    echo "  --name <name>         Customer name (required)"
    echo "  --phone <phone>       Phone number (required)"
    echo "  --address <address>   Delivery address (required)"
    echo "  --city <city>         City (required)"
    echo "  --payment <method>    Payment method: cod, transfer (default: cod)"
    echo ""
    echo -e "${BOLD}ENVIRONMENT:${NC}"
    echo "  ALYA_API_URL            API base URL (default: http://localhost:3000/api)"
    echo "  ALYA_SESSION_ID         Session ID for cart persistence"
    echo ""
    echo -e "${BOLD}EXAMPLES:${NC}"
    echo "  alya-shop products"
    echo "  alya-shop search dress"
    echo "  alya-shop category tops"
    echo "  alya-shop product floral-wrap-dress"
    echo "  alya-shop add floral-wrap-dress --size M --color \"Blue Floral\""
    echo "  alya-shop cart"
    echo "  alya-shop checkout --name \"John Doe\" --phone 08123456789 --address \"Jl. Test 123\" --city Jakarta"
    echo ""
}

cmd_products() {
    local sort="${1:-popular}"
    local limit="${2:-20}"

    echo -e "${BOLD}Fetching products...${NC}"
    echo ""

    response=$(curl -s "${BASE_URL}/products?sort=${sort}&limit=${limit}")

    if echo "$response" | jq -e '.success == true' > /dev/null 2>&1; then
        echo "$response" | jq -r '
            .data.products[] |
            "┌─────────────────────────────────────────────────────────────────────────────────
│ \(.name)
│ ID: \(.slug) | Category: \(.category)
│ Price: Rp \(.price) \(if .originalPrice then "  (was Rp \(.originalPrice))" else "" end)
│ Rating: ★ \(.rating) (\(.reviewCount) reviews) | Sold: \(.soldCount)
│ Sizes: \(.sizes | join(", "))
│ Colors: \(.colors | join(", "))
└─────────────────────────────────────────────────────────────────────────────────"'

        total=$(echo "$response" | jq -r '.data.pagination.total')
        echo ""
        echo -e "${CYAN}Total: ${total} products${NC}"
    else
        echo -e "${RED}Error fetching products${NC}"
        echo "$response" | jq -r '.error.message // "Unknown error"'
    fi
}

cmd_search() {
    local query="$1"
    if [ -z "$query" ]; then
        echo -e "${RED}Error: Search query required${NC}"
        echo "Usage: alya-shop search <query>"
        exit 1
    fi

    echo -e "${BOLD}Searching for: ${query}${NC}"
    echo ""

    response=$(curl -s "${BASE_URL}/products?search=${query}")

    if echo "$response" | jq -e '.success == true' > /dev/null 2>&1; then
        count=$(echo "$response" | jq -r '.data.products | length')
        if [ "$count" -eq 0 ]; then
            echo -e "${YELLOW}No products found for '${query}'${NC}"
        else
            echo "$response" | jq -r '
                .data.products[] |
                "\(.slug): \(.name) - Rp \(.price) [\(.category)]"'
            echo ""
            echo -e "${CYAN}Found: ${count} products${NC}"
        fi
    else
        echo -e "${RED}Error searching products${NC}"
    fi
}

cmd_category() {
    local category="$1"
    if [ -z "$category" ]; then
        echo -e "${RED}Error: Category required${NC}"
        echo "Available: tops, bottoms, dresses, outerwear, accessories"
        exit 1
    fi

    echo -e "${BOLD}Category: ${category}${NC}"
    echo ""

    response=$(curl -s "${BASE_URL}/products?category=${category}")

    if echo "$response" | jq -e '.success == true' > /dev/null 2>&1; then
        echo "$response" | jq -r '
            .data.products[] |
            "\(.slug): \(.name) - Rp \(.price)"'

        count=$(echo "$response" | jq -r '.data.products | length')
        echo ""
        echo -e "${CYAN}Found: ${count} products in ${category}${NC}"
    else
        echo -e "${RED}Error fetching category${NC}"
    fi
}

cmd_product() {
    local slug="$1"
    if [ -z "$slug" ]; then
        echo -e "${RED}Error: Product slug required${NC}"
        echo "Usage: alya-shop product <slug>"
        exit 1
    fi

    response=$(curl -s "${BASE_URL}/products/${slug}")

    if echo "$response" | jq -e '.success == true' > /dev/null 2>&1; then
        echo "$response" | jq -r '
            .data |
            "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
\(.name)
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

ID:          \(.slug)
Category:    \(.category)
Price:       Rp \(.price)\(if .originalPrice then "  (was Rp \(.originalPrice))" else "" end)
Rating:      ★ \(.rating) (\(.reviewCount) reviews)
Sold:        \(.soldCount)
In Stock:    \(if .inStock then "Yes" else "No" end)

Description:
\(.description)

Sizes:       \(.sizes | join(", "))
Colors:      \(.colors | join(", "))
Material:    \(.material // "N/A")

Care:
\(if .care then (.care | map("  • " + .) | join("\n")) else "  N/A" end)

━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
To add to cart: alya-shop add \(.slug) --size <size> --color <color>
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"'
    else
        echo -e "${RED}Product not found: ${slug}${NC}"
    fi
}

cmd_add() {
    local slug="$1"
    shift

    if [ -z "$slug" ]; then
        echo -e "${RED}Error: Product slug required${NC}"
        echo "Usage: alya-shop add <slug> [--size <size>] [--color <color>] [--qty <qty>]"
        exit 1
    fi

    local size=""
    local color=""
    local qty=1

    while [[ $# -gt 0 ]]; do
        case $1 in
            --size) size="$2"; shift 2 ;;
            --color) color="$2"; shift 2 ;;
            --qty) qty="$2"; shift 2 ;;
            *) shift ;;
        esac
    done

    local json_data="{\"productId\":\"${slug}\",\"quantity\":${qty}"
    [ -n "$size" ] && json_data="${json_data},\"size\":\"${size}\""
    [ -n "$color" ] && json_data="${json_data},\"color\":\"${color}\""
    json_data="${json_data}}"

    response=$(curl -s -X POST "${BASE_URL}/cart" \
        -H "Content-Type: application/json" \
        -H "X-Session-ID: ${SESSION_ID}" \
        -d "$json_data")

    if echo "$response" | jq -e '.success == true' > /dev/null 2>&1; then
        echo -e "${GREEN}✓ $(echo "$response" | jq -r '.message')${NC}"
        echo ""
        echo "Cart summary:"
        echo "$response" | jq -r '.data.cart | "  Items: \(.itemCount)\n  Subtotal: \(.formattedSubtotal)"'
    else
        echo -e "${RED}Error adding to cart${NC}"
        echo "$response" | jq -r '.error.message // "Unknown error"'
    fi
}

cmd_cart() {
    response=$(curl -s "${BASE_URL}/cart" \
        -H "X-Session-ID: ${SESSION_ID}")

    if echo "$response" | jq -e '.success == true' > /dev/null 2>&1; then
        count=$(echo "$response" | jq -r '.data.itemCount')

        if [ "$count" -eq 0 ]; then
            echo -e "${YELLOW}Your cart is empty${NC}"
            echo "Use 'alya-shop products' to browse and 'alya-shop add <slug>' to add items"
        else
            echo -e "${BOLD}Your Cart${NC}"
            echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
            echo ""
            echo "$response" | jq -r '
                .data.items[] |
                "  \(.productName)
    Size: \(.size) | Color: \(.color)
    Qty: \(.quantity) × Rp \(.price) = Rp \(.price * .quantity)
    Variant ID: \(.variantId)
"'
            echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
            echo "$response" | jq -r '"  Items: \(.data.itemCount)
  Subtotal: \(.data.formattedSubtotal)"'
            echo ""
            echo "To checkout: alya-shop checkout --name <name> --phone <phone> --address <addr> --city <city>"
        fi
    else
        echo -e "${RED}Error fetching cart${NC}"
    fi
}

cmd_remove() {
    local variant_id="$1"
    if [ -z "$variant_id" ]; then
        echo -e "${RED}Error: Variant ID required${NC}"
        echo "Usage: alya-shop remove <variant-id>"
        echo "Run 'alya-shop cart' to see variant IDs"
        exit 1
    fi

    response=$(curl -s -X DELETE "${BASE_URL}/cart?variantId=${variant_id}" \
        -H "X-Session-ID: ${SESSION_ID}")

    if echo "$response" | jq -e '.success == true' > /dev/null 2>&1; then
        echo -e "${GREEN}✓ $(echo "$response" | jq -r '.message')${NC}"
    else
        echo -e "${RED}Error removing item${NC}"
        echo "$response" | jq -r '.error.message // "Unknown error"'
    fi
}

cmd_clear() {
    response=$(curl -s -X DELETE "${BASE_URL}/cart" \
        -H "X-Session-ID: ${SESSION_ID}")

    if echo "$response" | jq -e '.success == true' > /dev/null 2>&1; then
        echo -e "${GREEN}✓ Cart cleared${NC}"
    else
        echo -e "${RED}Error clearing cart${NC}"
    fi
}

cmd_checkout() {
    local name=""
    local phone=""
    local address=""
    local city=""
    local payment="cod"

    while [[ $# -gt 0 ]]; do
        case $1 in
            --name) name="$2"; shift 2 ;;
            --phone) phone="$2"; shift 2 ;;
            --address) address="$2"; shift 2 ;;
            --city) city="$2"; shift 2 ;;
            --payment) payment="$2"; shift 2 ;;
            *) shift ;;
        esac
    done

    if [ -z "$name" ] || [ -z "$phone" ] || [ -z "$address" ] || [ -z "$city" ]; then
        echo -e "${RED}Error: Missing required fields${NC}"
        echo "Usage: alya-shop checkout --name <name> --phone <phone> --address <address> --city <city>"
        exit 1
    fi

    local json_data="{
        \"customer\": {
            \"name\": \"${name}\",
            \"phone\": \"${phone}\",
            \"address\": \"${address}\",
            \"city\": \"${city}\"
        },
        \"paymentMethod\": \"${payment}\"
    }"

    response=$(curl -s -X POST "${BASE_URL}/orders" \
        -H "Content-Type: application/json" \
        -H "X-Session-ID: ${SESSION_ID}" \
        -d "$json_data")

    if echo "$response" | jq -e '.success == true' > /dev/null 2>&1; then
        echo -e "${GREEN}✓ Order placed successfully!${NC}"
        echo ""
        echo "$response" | jq -r '
            .data.order |
            "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
ORDER CONFIRMATION
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

Order ID:    \(.id)
Status:      \(.status)
Date:        \(.createdAt)

Items:
\(.items | map("  • \(.productName) (\(.size), \(.color)) x\(.quantity) - Rp \(.price * .quantity)") | join("\n"))

━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
Subtotal:    Rp \(.subtotal)
Shipping:    Rp \(.shipping)\(if .shipping == 0 then " (FREE)" else "" end)
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
TOTAL:       Rp \(.total)
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

Ship To:
  \(.customer.name)
  \(.customer.phone)
  \(.customer.address)
  \(.customer.city)

Payment:     \(.paymentMethod | ascii_upcase)
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"'
        echo ""
        echo -e "${CYAN}$(echo "$response" | jq -r '.data.nextSteps')${NC}"
    else
        echo -e "${RED}Error placing order${NC}"
        echo "$response" | jq -r '.error.message // "Unknown error"'
    fi
}

cmd_orders() {
    response=$(curl -s "${BASE_URL}/orders" \
        -H "X-Session-ID: ${SESSION_ID}")

    if echo "$response" | jq -e '.success == true' > /dev/null 2>&1; then
        count=$(echo "$response" | jq -r '.data.count')

        if [ "$count" -eq 0 ]; then
            echo -e "${YELLOW}No orders found${NC}"
        else
            echo -e "${BOLD}Your Orders${NC}"
            echo ""
            echo "$response" | jq -r '
                .data.orders[] |
                "\(.id) | \(.status) | Rp \(.total) | \(.items | length) items | \(.createdAt | split("T")[0])"'
        fi
    else
        echo -e "${RED}Error fetching orders${NC}"
    fi
}

cmd_order() {
    local order_id="$1"
    if [ -z "$order_id" ]; then
        echo -e "${RED}Error: Order ID required${NC}"
        echo "Usage: alya-shop order <order-id>"
        exit 1
    fi

    response=$(curl -s "${BASE_URL}/orders?id=${order_id}")

    if echo "$response" | jq -e '.success == true' > /dev/null 2>&1; then
        echo "$response" | jq -r '
            .data |
            "Order: \(.id)
Status: \(.status)
Date: \(.createdAt)

Items:
\(.items | map("  \(.productName) (\(.size), \(.color)) x\(.quantity) - Rp \(.price * .quantity)") | join("\n"))

Subtotal: Rp \(.subtotal)
Shipping: Rp \(.shipping)
Total: Rp \(.total)

Ship to: \(.customer.name), \(.customer.address), \(.customer.city)"'
    else
        echo -e "${RED}Order not found${NC}"
    fi
}

# Main
case "${1:-help}" in
    help|--help|-h) cmd_help ;;
    products|list|ls) cmd_products "$2" "$3" ;;
    search|find) cmd_search "$2" ;;
    category|cat) cmd_category "$2" ;;
    product|view|show) cmd_product "$2" ;;
    add|buy) shift; cmd_add "$@" ;;
    cart|basket) cmd_cart ;;
    remove|rm|delete) cmd_remove "$2" ;;
    clear) cmd_clear ;;
    checkout|order) shift; cmd_checkout "$@" ;;
    orders) cmd_orders ;;
    order) cmd_order "$2" ;;
    *)
        echo -e "${RED}Unknown command: $1${NC}"
        echo "Run 'alya-shop help' for usage"
        exit 1
        ;;
esac
